{
  "name": "@radar/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/generate-public-metadata.mjs --production",
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test:entitlements": "node tests/plan-access.test.mjs",
    "test:kline-confirmation": "node tests/kline-confirmation.test.mjs",
    "test:kline-realtime": "node tests/kline-realtime.test.mjs",
    "test:kline-strategy-source": "node tests/kline-lab-strategy-source.test.mjs",
    "test:radar-live": "node tests/live-signal-command.test.mjs",
    "test:touch-targets": "node tests/touch-targets.test.mjs",
    "test:portal-source": "node tests/public-portal-source.test.mjs",
    "test:public-metadata": "node tests/public-metadata.test.mjs",
    "test:portal-runtime": "node tests/public-portal-runtime.test.mjs",
    "test:prompt-focus": "node tests/prompt-focus.test.mjs",
    "test:portal-routing": "node tests/portal-routing.test.mjs",
    "test:public-performance": "node tests/public-performance.test.mjs",
    "test:view-routing": "node tests/view-routing.test.mjs"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
